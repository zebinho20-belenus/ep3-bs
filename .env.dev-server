# DEV server environment — copy to .env on the dev server
# cp .env.dev-server .env  (then adjust passwords)
#
# Usage: docker compose -f docker-compose.dev-server.yml up -d

# App Hostname (Traefik routing — must differ from production)
APP_HOSTNAME=dev.platzbuchung.tcn-kail.de

# MariaDB (use different port than production's 3306)
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=mycourt
MYSQL_USER=prod_mycourt
MYSQL_PASSWORD=CHANGE_ME
MYSQL_PORT=3668

# No Xdebug on server
INSTALL_XDEBUG=false
