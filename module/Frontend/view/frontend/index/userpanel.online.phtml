<div class="d-flex flex-wrap align-items-center gap-2">
    <span id="userpanel-status" class="no-wrap me-2 d-none d-lg-inline">
        <?= sprintf($this->t('Online as %s'), $this->escapeHtml($this->user->need('alias'))) ?>
    </span>

    <?php if ($this->user->can('admin.see-menu')): ?>
        <?php $this->headScript()->appendFile($this->basePath('js/controller/frontend/index.admin.min.js')) ?>
        <a href="<?= $this->url('backend') ?>" id="admin-menu-link" class="btn btn-outline-primary btn-sm">
            <span class="fa fa-cog"></span>
            <span class="symbolic-label"><?= $this->t('Administration') ?></span>
        </a>
    <?php endif; ?>

    <a href="<?= $this->url('frontend') ?>" class="btn btn-outline-primary btn-sm">
        <span class="fa fa-calendar"></span>
        <span class="symbolic-label"><?= $this->t('Calendar') ?></span>
    </a>

    <?php $lastBookingsHelper = $this->plugin('UserLastBookings'); ?>
    <?php $tooltipHtml = $lastBookingsHelper($this->user); ?>
    <?php $unpaidCount = $lastBookingsHelper->unpaidCount; ?>
    <?php $upcomingCount = $lastBookingsHelper->upcomingCount; ?>
    <a href="<?= $this->url('user/bookings') ?>" class="btn btn-outline-primary btn-sm" style="position: relative;" data-tooltip="<?= htmlspecialchars($tooltipHtml, ENT_QUOTES, 'UTF-8') ?>">
        <span class="fa fa-list"></span>
        <span class="symbolic-label"><?= $this->t('My bookings') ?></span>
        <?php if ($unpaidCount > 0): ?>
            <span class="notification-badge notification-badge-warning" tabindex="0" data-popover-content="<?= htmlspecialchars($tooltipHtml, ENT_QUOTES, 'UTF-8') ?>"><?= $unpaidCount ?></span>
        <?php elseif ($upcomingCount > 0): ?>
            <span class="notification-badge notification-badge-success" tabindex="0" data-popover-content="<?= htmlspecialchars($tooltipHtml, ENT_QUOTES, 'UTF-8') ?>"><?= $upcomingCount ?></span>
        <?php endif; ?>
    </a>

    <a href="<?= $this->url('user/settings') ?>" class="btn btn-outline-primary btn-sm">
        <span class="fa fa-user"></span>
        <span class="symbolic-label"><?= $this->t('My account') ?></span>
    </a>

    <a href="<?= $this->url('user/logout') ?>" class="btn btn-outline-secondary btn-sm">
        <span class="fa fa-sign-out"></span>
        <span class="symbolic-label"><?= $this->t('Logout') ?></span>
    </a>

    <a href="<?= $this->url('service/help') ?>" class="btn btn-outline-secondary btn-sm ms-1" data-tooltip="<?= htmlspecialchars(sprintf($this->t('Get additional %shelp and information%s'), '', ''), ENT_QUOTES, 'UTF-8') ?>">
        <b>?</b>
    </a>
</div>
