<?php

$square = $this->square;
$squareType = $this->option('subject.square.type');

$dateStart = $this->dateStart;
$dateEnd = $this->dateEnd;

$this->setup(array(
    'title' => sprintf('%s-%s', $squareType, $this->t('Booking')),
    'panel' => 'centered-panel',
    'messages' => array(
        'error' => $this->message,
    ),
    'back' => true,
));

?>

<script type="text/javascript">
var EP3_LABELS = {
    processing: <?= json_encode($this->t('Processing payment ...'), JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT) ?>,
    goToPayment: <?= json_encode($this->t('go to payment'), JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT) ?>,
    completeBooking: <?= json_encode($this->t('Complete booking'), JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT) ?>
};
function showHide() {
   var div = document.getElementById('hidden_div');
   if (div.style.display == 'none') {
     div.style = 'position:fixed; top:0; right:0; bottom:0; left:0; background-color: rgba(0,0,0,0.5); z-index: 9999; display:flex; align-items:center; justify-content:center;';
     div.innerHTML = '<div style="text-align:center;color:#fff"><div class="spinner-border text-light mb-3" role="status"></div><div>' + EP3_LABELS.processing + '</div></div>';
     div.setAttribute('aria-busy', 'true');
   }
   else {
     div.style.display = 'none';
   }
}
function setPaymentLabel(label) {
   document.getElementById('bf-submit').value = label;
}
</script>

<div class="p-3">

    <form id="confirmform" method="post" onSubmit="showHide();" action="<?= $this->url ?>">
<?php

        $pricingSummary = $this->squarePricingSummary($dateStart, $dateEnd, $square, $this->quantityChoosen, $this->products, $this->guestPlayer);

        if ($pricingSummary) {
            echo '<p class="text-center text-muted"><em>' . $this->t('Summary of your booking:') . '</em></p>';
            echo '<div class="card card-body bg-light mb-3">' . $pricingSummary . '</div>';
        }

?>

        <?php if ($this->hasBudget): ?>
        <div class="alert alert-info">
            <strong><?= $this->t('payment from open budget') ?>:</strong><br>
            Budget: <?= $this->budget ?> &rarr; <?= $this->t('new budget') ?>: <?= $this->newbudget ?>
        </div>
        <?php endif; ?>

        <?php if ($square->getMeta('rules.document.file')): ?>

            <div class="alert alert-warning">
                <p class="mb-2"><strong><?= $this->t('Please note') ?>:</strong></p>

                <p>
                    <a href="<?= $this->basePath('../extern/hallenordnung11.pdf') ?>" class="btn btn-outline-secondary btn-sm" target="_blank">
                        <span class="fa fa-file-pdf-o"></span> <?= $square->getMeta('rules.document.name', $this->t('Rules-document')) ?>
                    </a>
                    <span class="text-muted small">(<?= $this->t('this will open in a new window') ?>)</span>
                </p>

                <div class="form-check">
                    <input type="checkbox" name="bf-accept-rules-document" id="bf-accept-rules-document" class="form-check-input">
                    <label for="bf-accept-rules-document" class="form-check-label"><?= sprintf($this->t('Yes, I have %1$sread and accepted%2$s the "%3$s"'), '<b>', '</b>', $square->getMeta('rules.document.name', $this->t('Rules-document'))) ?></label>
                </div>
            </div>

        <?php endif; ?>

        <?php if ($square->getMeta('rules.text')): ?>

            <div class="alert alert-warning">
                <p class="mb-2"><strong><?= $this->t('Please note') ?>:</strong></p>
                <div class="rules-text-scroll mb-2"><?= $square->getMeta('rules.text') ?></div>
                <div class="form-check">
                    <input type="checkbox" name="bf-accept-rules-text" id="bf-accept-rules-text" class="form-check-input">
                    <label for="bf-accept-rules-text" class="form-check-label"><?= sprintf($this->t('Yes, I have %sread and accepted%s these rules and notes'), '<b>', '</b>') ?></label>
                </div>
            </div>

        <?php endif; ?>

        <?php if ($square->get('allow_notes')): ?>
            <div class="mb-3">
                <textarea name="bf-user-notes" placeholder="Optionale Anmerkungen" class="form-control" rows="2"></textarea>
            </div>
        <?php endif; ?>

        <div class="text-center text-muted small mb-3">

        <?php

            $cancelRange = $square->need('range_cancel');

            if ($cancelRange) {
                printf($this->t('Your booking will be binding, however, you can cancel it up to %s before it takes place.'),
                    $this->prettyTime($cancelRange));
            } else {
                echo $this->t('Your booking will be binding.');
            }

            $guestPlayer = $this->guestPlayer;

            if ($guestPlayer && !$this->budgetpayment) {
                echo '<div class="guest-payment-instructions mt-2">';
                echo $this->t('Guest booking: You can pay now via PayPal Friends & Family or choose to pay later.');
                echo '</div>';
            }

            ?>
        </div>

        <div class="text-center">
            <input type="hidden" name="bf-confirm" value="<?= htmlspecialchars($this->csrfToken, ENT_QUOTES, 'UTF-8') ?>">

            <?php if ($this->payable): ?>

            <div class="payment-options">
            <?php if ($this->paypal): ?>
                <label for="paypal" class="payment_radio">
                    <input type="radio" id="paypal" name="paymentservice" value="paypal" <?php if ($this->payment_default == 'paypal'): ?>checked<?php endif; ?> onclick="if(this.checked){setPaymentLabel(EP3_LABELS.goToPayment)}">
                    <img src="<?= $this->basePath('imgs-client/layout/paypal.png') ?>" alt="PayPal" />
                </label>
            <?php endif; ?>
            <?php if ($this->stripe): ?>
                <label for="stripe" class="payment_radio">
                    <input type="radio" id="stripe" name="paymentservice" value="stripe" <?php if ($this->payment_default == 'stripe'): ?>checked<?php endif; ?> onclick="if(this.checked){setPaymentLabel(EP3_LABELS.goToPayment)}">
                    <img src="<?= $this->basePath('imgs-client/layout/stripe_icons/'.$this->stripeIcon) ?>" alt="Stripe" />
                </label>
            <?php endif; ?>
            <?php if ($this->klarna): ?>
                <label for="klarna" class="payment_radio">
                    <input type="radio" id="klarna" name="paymentservice" value="klarna" <?php if ($this->payment_default == 'klarna'): ?>checked<?php endif; ?> onclick="if(this.checked){setPaymentLabel(EP3_LABELS.goToPayment)}">
                    <span class="payment-label">Klarna</span>
                </label>
            <?php endif; ?>
            <?php if ($this->billing): ?>
                <label for="billing" class="payment_radio">
                    <input type="radio" id="billing" name="paymentservice" value="billing" <?php if ($this->payment_default == 'billing'): ?>checked<?php endif; ?> onclick="if(this.checked){setPaymentLabel(EP3_LABELS.completeBooking)}">
                    <img src="<?= $this->basePath('imgs-client/layout/rechnung.svg') ?>" alt="Rechnung" />
                </label>
            <?php endif; ?>
            <?php if ($guestPlayer && !$this->billing): ?>
                <label for="billing" class="payment_radio">
                    <input type="radio" id="billing" name="paymentservice" value="billing" onclick="if(this.checked){setPaymentLabel(EP3_LABELS.completeBooking)}">
                    <span class="payment-label"><?= $this->t('Pay later') ?></span>
                </label>
            <?php endif; ?>
            </div>

            <?php if ($this->paypal || $this->stripe || $this->klarna): ?>
                <input type="submit" name="bf-submit" id="bf-submit" value="<?= $this->t('go to payment') ?>" class="btn btn-primary btn-lg w-100 mt-2">
            <?php else: ?>
                <input type="submit" name="bf-submit" id="bf-submit" value="<?= $this->t('Complete booking') ?>" class="btn btn-primary btn-lg w-100 mt-2">
            <?php endif; ?>

            <?php else: ?>
                <?php if ($this->budgetpayment): ?>
                    <input type="submit" name="bf-submit" id="bf-submit" value="<?= $this->t('Pay with budget') ?>" class="btn btn-accent btn-lg w-100 mt-2">
                <?php else: ?>
                    <input type="submit" name="bf-submit" id="bf-submit" value="<?= $this->t('Complete booking') ?>" class="btn btn-primary btn-lg w-100 mt-2">
                <?php endif; ?>
            <?php endif; ?>
        </div>

    </form>

</div>

<div id="hidden_div" style="display:none"></div>
