<?php

$this->setup(array(
    'title' => $this->event->getMeta('name'),
    'panel' => 'centered-panel',
    'back' => true,
));

$name = $this->event->getMeta('name');
$description = $this->event->getMeta('description');

if ($this->square) {
    $location = sprintf('%s %s', $this->option('subject.square.type'), $this->square->need('name'));
} else {
    $location = sprintf($this->t('All %s'), $this->option('subject.square.type.plural'));
}

?>

<div class="text-center px-3 py-2">

    <h4 class="fw-semibold mb-3"><?= $this->escapeHtml($name) ?></h4>

    <div class="mb-3">
        <span class="fa fa-calendar text-muted me-1"></span>
        <?= $this->squareDateFormat($this->event->needExtra('datetime_start'), $this->event->needExtra('datetime_end')) ?>
    </div>

    <div class="mb-3">
        <span class="fa fa-map-marker text-muted me-1"></span>
        <span class="fw-medium"><?= $this->escapeHtml($location) ?></span>
    </div>

    <?php if ($description): ?>
    <hr class="my-2">
    <div class="text-start small text-muted" style="max-width: 480px; margin: 0 auto;">
        <?= $description ?>
    </div>
    <?php endif; ?>

</div>