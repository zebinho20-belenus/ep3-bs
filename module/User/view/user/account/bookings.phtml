<?php

$this->setup(array(
    'title' => 'My bookings',
    'panel' => 'centered-panel',
    'back' => true,
    'links' => array(
        'Calendar' => $this->url('frontend'),
        'My account' => $this->url('user/settings'),
    ),
));

?>

<div>
    <h1><?= $this->t('My bookings') ?></h1>

    <div class="separator-small"></div>

    <?php if ($this->sessionUser()): ?>
    <div class="mb-3 no-print">
        <div class="d-flex flex-wrap align-items-center gap-2 justify-content-center">
            <a href="<?= $this->url('frontend') ?>" class="btn btn-outline-primary btn-sm">
                <span class="fa fa-calendar"></span>
                <span class="symbolic-label"><?= $this->t('Calendar') ?></span>
            </a>
            <a href="<?= $this->url('user/settings') ?>" class="btn btn-outline-primary btn-sm">
                <span class="fa fa-user"></span>
                <span class="symbolic-label"><?= $this->t('My account') ?></span>
            </a>
        </div>
    </div>
    <?php endif; ?>

    <div class="separator-small"></div>

    <?php if (count($this->bookings) == 0): ?>
        <p><?= sprintf($this->t('You have not booked any %s yet.'), $this->option('subject.square.type.plural')) ?></p>
    <?php elseif (count($this->bookings) == 1): ?>
        <p><?= sprintf($this->t('You have already booked one %s.'), $this->option('subject.square.type')) ?></p>
    <?php else: ?>
        <p><?= sprintf($this->t('You have already booked %s %s.'), count($this->bookings), $this->option('subject.square.type.plural')) ?></p>
    <?php endif; ?>

    <?php if (count($this->bookings) > 0): ?>

        <hr>

        <div class="table-responsive">
        <table class="table table-hover align-middle">
            <tbody>
            <?php

            $todayMentioned = false;

            foreach ($this->bookings as $bid => $booking) {
                $reservations = $booking->needExtra('reservations');

                $bookingDateTimeStart = null;
                $bookingDateTimeEnd = null;

                foreach ($reservations as $reservation) {
                    $tmpDateTimeStart = new DateTime($reservation->need('date') . ' ' . $reservation->need('time_start'));
                    $tmpDateTimeEnd = new DateTime($reservation->need('date') . ' ' . $reservation->need('time_end'));

                    if (is_null($bookingDateTimeStart) || $tmpDateTimeStart < $bookingDateTimeStart) {
                        $bookingDateTimeStart = $tmpDateTimeStart;
                    }

                    if (is_null($bookingDateTimeEnd) || $tmpDateTimeEnd < $bookingDateTimeStart) {
                        $bookingDateTimeEnd = $tmpDateTimeEnd;
                    }
                }

                $cancellable = false;
                $rowClass = '';

                $square = $this->squareManager->get($booking->need('sid'));

                if ($this->now > $bookingDateTimeStart) {
                    $rowClass = ' class="text-muted"';

                    if (! $todayMentioned) {
                        echo '<tr><td colspan="4">';
                        echo '<div class="text-center position-relative py-2">';
                        echo '<hr class="my-0">';
                        echo '<span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">' . $this->t('Now') . '</span>';
                        echo '</div>';
                        echo '</td></tr>';

                        $todayMentioned = true;
                    }
                } else {
                    $cancellable = $this->squareValidator->isCancellable($booking);
                }

                $bills = $booking->getExtra('bills');
                $statusBilling = $booking->get('status_billing');

                if ($bills) {
                    $price = 0;

                    foreach ($bills as $bill) {
                        $price += $bill->need('price');
                    }

                    $pricing = '<a href="' . $this->url('user/bookings/bills', ['bid' => $bid]) . '" class="btn btn-outline-primary btn-sm">';
                    $pricing .= $this->priceFormat($price);
                    $pricing .= '</a>';
                } else {
                    $pricing = '<span class="text-muted">&middot;</span>';
                }

                /* Billing status badge (#5) */
                if ($statusBilling == 'pending' && $price > 0) {
                    $pricing .= ' <span class="badge bg-warning text-dark">' . $this->t('Pending') . '</span>';
                } elseif ($statusBilling == 'paid') {
                    $pricing .= ' <span class="badge bg-success">' . $this->t('Paid') . '</span>';
                }

                echo '<tr' . $rowClass . '>';

                $nameClass = ($this->now <= $bookingDateTimeStart) ? 'text-success fw-semibold' : 'text-muted';
                echo '<td class="' . $nameClass . '">' . $this->option('subject.square.type') . ' ' . $this->t($square->need('name')) . '</td>';
                echo '<td>' . $this->dateRange($bookingDateTimeStart, $bookingDateTimeEnd) . '</td>';
                echo '<td>' . $pricing . '</td>';

                if ($cancellable) {
                    echo sprintf('<td><a href="%s" class="btn btn-outline-danger btn-sm">%s</a></td>',
                        $this->url('square/booking/cancellation', [], ['query' => ['bid' => $booking->need('bid')]]), $this->t('Cancel booking'));
                } else {
                    echo '<td class="text-center text-muted">&middot;</td>';
                }

                echo '</tr>';
            }

            ?>
            </tbody>
        </table>
        </div>

    <?php endif; ?>

</div>
