<?php

$this->setup(array(
    'title' => 'My bookings',
    'panel' => 'centered-panel',
    'back' => true,
    'links' => array(
        'Calendar' => $this->url('frontend'),
        'My account' => $this->url('user/settings'),
    ),
));

$this->headScript()->appendFile($this->basePath('js/controller/user/bookings.min.js'));

?>

<div>
    <h1><?= $this->t('My bookings') ?></h1>

    <div class="separator-small"></div>

    <?php if ($this->sessionUser()): ?>
    <div class="mb-3 no-print">
        <div class="d-flex flex-wrap align-items-center gap-2 justify-content-center">
            <a href="<?= $this->url('frontend') ?>" class="btn btn-outline-primary btn-sm">
                <span class="fa fa-calendar"></span>
                <span class="symbolic-label"><?= $this->t('Calendar') ?></span>
            </a>
            <a href="<?= $this->url('user/settings') ?>" class="btn btn-outline-primary btn-sm">
                <span class="fa fa-user"></span>
                <span class="symbolic-label"><?= $this->t('My account') ?></span>
            </a>
        </div>
    </div>
    <?php endif; ?>

    <div class="separator-small"></div>

    <?php if (count($this->bookings) == 0): ?>
        <p><?= sprintf($this->t('You have not booked any %s yet.'), $this->option('subject.square.type.plural')) ?></p>
    <?php elseif (count($this->bookings) == 1): ?>
        <p><?= sprintf($this->t('You have already booked one %s.'), $this->option('subject.square.type')) ?></p>
    <?php else: ?>
        <p><?= sprintf($this->t('You have already booked %s %s.'), count($this->bookings), $this->option('subject.square.type.plural')) ?></p>
    <?php endif; ?>

    <?php if (count($this->bookings) > 0): ?>

        <hr>

        <div id="bookings-filter" class="btn-group mb-3 no-print" role="group">
            <input type="radio" class="btn-check" name="bookings-filter" id="filter-all" value="all" autocomplete="off" checked>
            <label class="btn btn-outline-primary btn-sm" for="filter-all"><?= $this->t('All') ?></label>

            <input type="radio" class="btn-check" name="bookings-filter" id="filter-upcoming" value="upcoming" autocomplete="off">
            <label class="btn btn-outline-primary btn-sm" for="filter-upcoming"><?= $this->t('Upcoming') ?></label>

            <input type="radio" class="btn-check" name="bookings-filter" id="filter-pending" value="pending" autocomplete="off">
            <label class="btn btn-outline-primary btn-sm" for="filter-pending"><?= $this->t('Pending') ?></label>
        </div>

        <table id="bookings-table" class="table table-hover align-middle">
            <tbody>
            <?php

            $todayMentioned = false;

            foreach ($this->bookings as $bid => $booking) {
                $reservations = $booking->needExtra('reservations');

                $bookingDateTimeStart = null;
                $bookingDateTimeEnd = null;

                foreach ($reservations as $reservation) {
                    $tmpDateTimeStart = new DateTime($reservation->need('date') . ' ' . $reservation->need('time_start'));
                    $tmpDateTimeEnd = new DateTime($reservation->need('date') . ' ' . $reservation->need('time_end'));

                    if (is_null($bookingDateTimeStart) || $tmpDateTimeStart < $bookingDateTimeStart) {
                        $bookingDateTimeStart = $tmpDateTimeStart;
                    }

                    if (is_null($bookingDateTimeEnd) || $tmpDateTimeEnd < $bookingDateTimeStart) {
                        $bookingDateTimeEnd = $tmpDateTimeEnd;
                    }
                }

                $cancellable = false;
                $rowClass = '';

                $square = $this->squareManager->get($booking->need('sid'));

                $bills = $booking->getExtra('bills');
                $statusBilling = $booking->get('status_billing');

                $price = 0;
                if ($bills) {
                    foreach ($bills as $bill) {
                        $price += $bill->need('price');
                    }
                }

                $isFuture = ($this->now <= $bookingDateTimeStart);
                $dataTime = $isFuture ? 'future' : 'past';
                $dataStatus = ($statusBilling == 'pending' && $price > 0) ? 'pending' : (($statusBilling == 'paid') ? 'paid' : 'free');

                if (! $isFuture) {
                    $rowClass = ' text-muted';

                    if (! $todayMentioned) {
                        echo '<tr class="separator-row"><td colspan="4">';
                        echo '<div class="text-center position-relative py-2">';
                        echo '<hr class="my-0">';
                        echo '<span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">' . $this->t('Now') . '</span>';
                        echo '</div>';
                        echo '</td></tr>';

                        $todayMentioned = true;
                    }
                } else {
                    $cancellable = $this->squareValidator->isCancellable($booking);

                    if ($dataStatus == 'pending') {
                        $rowClass = ' table-warning';
                    }
                }

                if ($bills) {
                    $pricing = '<a href="' . $this->url('user/bookings/bills', ['bid' => $bid]) . '" class="btn btn-outline-primary btn-sm">';
                    $pricing .= $this->priceFormat($price);
                    $pricing .= '</a>';
                } else {
                    $pricing = '<span class="text-muted">&middot;</span>';
                }

                /* Billing status badge (#5) */
                if ($statusBilling == 'pending' && $price > 0) {
                    $pricing .= ' <span class="badge bg-warning text-dark">' . $this->t('Pending') . '</span>';
                } elseif ($statusBilling == 'paid') {
                    $pricing .= ' <span class="badge bg-success">' . $this->t('Paid') . '</span>';
                }

                echo '<tr class="booking-row' . $rowClass . '" data-time="' . $dataTime . '" data-status="' . $dataStatus . '">';

                $nameClass = $isFuture ? 'text-success fw-semibold' : 'text-muted';
                echo '<td data-label="' . htmlspecialchars($this->option('subject.square.type')) . '" class="' . $nameClass . '">' . $this->option('subject.square.type') . ' ' . $this->t($square->need('name')) . '</td>';
                echo '<td data-label="' . $this->t('Date') . '">' . $this->dateRange($bookingDateTimeStart, $bookingDateTimeEnd) . '</td>';
                echo '<td data-label="' . $this->t('Price') . '">' . $pricing . '</td>';

                if ($cancellable) {
                    echo sprintf('<td class="bookings-action-col"><a href="%s" class="btn btn-outline-danger btn-sm"><span class="d-none d-sm-inline">%s</span><span class="d-sm-none">%s</span></a></td>',
                        $this->url('square/booking/cancellation', [], ['query' => ['bid' => $booking->need('bid')]]), $this->t('Cancel booking'), $this->t('Cancel'));
                } else {
                    echo '<td class="bookings-action-col text-center text-muted">&middot;</td>';
                }

                echo '</tr>';
            }

            ?>
            <tr class="no-results-row" style="display: none;">
                <td colspan="4" class="text-center text-muted py-3"><?= $this->t('No matching bookings') ?></td>
            </tr>
            </tbody>
        </table>

    <?php endif; ?>

</div>
