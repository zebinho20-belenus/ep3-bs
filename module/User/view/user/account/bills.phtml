<?php

if ($this->user->can('admin.bookings')) {
    $back = true;

    $links = array(
        'Edit bill' => $this->url('backend/booking/bills', ['bid' => $this->booking->need('bid')]),
    );
} else {
    $back = array(
        'My bookings' => $this->url('user/bookings'),
    );

    $links = array();
}

$this->setup(array(
    'title' => 'Booking-Bill',
    'panel' => 'centered-panel',
    'back' => $back,
    'links' => $links,
));

?>

<div>
    <h1><?= $this->t('Booking-Bill') ?></h1>

    <div class="separator-small"></div>

    <?php
        $statusCssMap = array(
            'paid' => 'billing-paid',
            'pending' => 'billing-pending',
            'cancelled' => 'billing-cancelled',
            'uncollectable' => 'billing-uncollectable',
            'member' => 'billing-member',
        );
        $slug = isset($this->bookingBillingStatusSlug) ? $this->bookingBillingStatusSlug : '';
        $cssClass = isset($statusCssMap[$slug]) ? $statusCssMap[$slug] : 'billing-pending';
    ?>
    <p><?= $this->t('Status') ?>: <span class="billing-badge <?= $cssClass ?>"><?= $this->escapeHtml($this->bookingBillingStatus) ?></span></p>

    <div class="card card-body bg-light bills-card">
        <div class="table-responsive">
        <table class="table table-bordered align-middle mb-0 bills-table">

            <?php

            $total = 0;

            ?>

            <?php foreach ($this->bills as $bill): ?>

                <?php

                if ($bill->get('quantity') == 1) {
                    $squareUnit = $this->option('subject.square.unit');
                } else {
                    $squareUnit = $this->option('subject.square.unit.plural');
                }

                $total += $bill->get('price');

                ?>

                <tr>
                    <td data-label="<?= $this->t('Description') ?>"><?= $bill->get('description') ?></td>

                    <?php if ($bill->get('time')): ?>
                        <td data-label="<?= $this->t('Time') ?>"><?= $this->prettyTime($bill->get('time')) ?></td>
                        <td data-label="<?= $this->t('Quantity') ?>"><?= $this->numberFormat($bill->get('quantity')) . ' ' . $squareUnit ?></td>
                    <?php else: ?>
                        <td colspan="2" data-label="<?= $this->t('Quantity') ?>"><?= sprintf($this->t('%s items'), $bill->get('quantity')) ?></td>
                    <?php endif; ?>

                    <td data-label="<?= $this->t('Price') ?>"><?= $this->priceFormat($bill->get('price'), $bill->get('rate'), $bill->get('gross')) ?></td>
                </tr>

            <?php endforeach; ?>

            <tr class="table-active fw-bold bills-total-row">
                <td colspan="3" data-label=""><?= $this->t('Total') ?></td>
                <td data-label="<?= $this->t('Total') ?>"><?= $this->priceFormat($total) ?></td>
            </tr>

        </table>
        </div>
    </div>

    <?php
    $paymentConfig = isset($this->paymentConfig) ? $this->paymentConfig : array();
    $hasPaymentOption = !empty($paymentConfig['paypal']) || !empty($paymentConfig['stripe']) || !empty($paymentConfig['klarna']);
    $isPending = ($this->bookingBillingStatusSlug == 'pending');
    $isNotCancelled = ($this->booking->get('status') != 'cancelled');
    ?>

    <?php if ($isPending && $isNotCancelled && $total > 0 && $hasPaymentOption): ?>

    <div class="mt-4">
        <form method="post" action="<?= $this->url('square/booking/payment_pay', ['bid' => $this->booking->need('bid')]) ?>">

            <p class="text-center text-muted mb-3"><?= $this->t('Pay open bill now:') ?></p>

            <div class="payment-options">
            <?php if (!empty($paymentConfig['paypal'])): ?>
                <label for="paypal" class="payment_radio">
                    <input type="radio" id="paypal" name="paymentservice" value="paypal" <?php if (isset($paymentConfig['payment_default']) && $paymentConfig['payment_default'] == 'paypal'): ?>checked<?php endif; ?>>
                    <img src="<?= $this->basePath('imgs-client/layout/paypal.png') ?>" alt="PayPal" />
                </label>
            <?php endif; ?>
            <?php if (!empty($paymentConfig['stripe'])): ?>
                <label for="stripe" class="payment_radio">
                    <input type="radio" id="stripe" name="paymentservice" value="stripe" <?php if (isset($paymentConfig['payment_default']) && $paymentConfig['payment_default'] == 'stripe'): ?>checked<?php endif; ?>>
                    <img src="<?= $this->basePath('imgs-client/layout/stripe_icons/' . $paymentConfig['stripeIcon']) ?>" alt="Stripe" />
                </label>
            <?php endif; ?>
            <?php if (!empty($paymentConfig['klarna'])): ?>
                <label for="klarna" class="payment_radio">
                    <input type="radio" id="klarna" name="paymentservice" value="klarna" <?php if (isset($paymentConfig['payment_default']) && $paymentConfig['payment_default'] == 'klarna'): ?>checked<?php endif; ?>>
                    <span class="payment-label">Klarna</span>
                </label>
            <?php endif; ?>
            </div>

            <div class="text-center mt-3">
                <input type="submit" value="<?= $this->t('Pay now') ?>" class="btn btn-primary btn-lg w-100">
            </div>

        </form>
    </div>

    <?php endif; ?>
</div>
