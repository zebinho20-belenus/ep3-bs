<?php

if ($this->user->can('admin.bookings')) {
    $back = true;

    $links = array(
        'Edit bill' => $this->url('backend/booking/bills', ['bid' => $this->booking->need('bid')]),
    );
} else {
    $back = array(
        'My bookings' => $this->url('user/bookings'),
    );

    $links = array();
}

$this->setup(array(
    'title' => 'Booking-Bill',
    'panel' => 'centered-panel',
    'back' => $back,
    'links' => $links,
));

?>

<div>
    <h1><?= $this->t('Booking-Bill') ?></h1>

    <div class="separator-small"></div>

    <?php
        $statusCssMap = array(
            'paid' => 'billing-paid',
            'pending' => 'billing-pending',
            'cancelled' => 'billing-cancelled',
            'uncollectable' => 'billing-uncollectable',
            'member' => 'billing-member',
        );
        $slug = isset($this->bookingBillingStatusSlug) ? $this->bookingBillingStatusSlug : '';
        $cssClass = isset($statusCssMap[$slug]) ? $statusCssMap[$slug] : 'billing-pending';
    ?>
    <p><?= $this->t('Status') ?>: <span class="billing-badge <?= $cssClass ?>"><?= $this->escapeHtml($this->bookingBillingStatus) ?></span></p>

    <div class="card card-body bg-light">
        <div class="table-responsive">
        <table class="table table-bordered align-middle mb-0">

            <?php

            $total = 0;

            ?>

            <?php foreach ($this->bills as $bill): ?>

                <?php

                if ($bill->get('quantity') == 1) {
                    $squareUnit = $this->option('subject.square.unit');
                } else {
                    $squareUnit = $this->option('subject.square.unit.plural');
                }

                $total += $bill->get('price');

                ?>

                <tr>
                    <td><?= $bill->get('description') ?></td>

                    <?php if ($bill->get('time')): ?>
                        <td><?= $this->prettyTime($bill->get('time')) ?></td>
                        <td><?= $this->numberFormat($bill->get('quantity')) . ' ' . $squareUnit ?></td>
                    <?php else: ?>
                        <td colspan="2"><?= sprintf($this->t('%s items'), $bill->get('quantity')) ?></td>
                    <?php endif; ?>

                    <td><?= $this->priceFormat($bill->get('price'), $bill->get('rate'), $bill->get('gross')) ?></td>
                </tr>

            <?php endforeach; ?>

            <tr class="table-active fw-bold">
                <td colspan="3"><?= $this->t('Total') ?></td>
                <td><?= $this->priceFormat($total) ?></td>
            </tr>

        </table>
        </div>
    </div>
</div>
