        <small class="text-muted">(<?= $this->t('please inform us about changes, so we can update this data') ?>)</small>

        <div class="mt-2">
            <?php

            /* Print gender and name */

            if ($this->user->getMeta('gender') && $this->user->getMeta('name')) {
                echo '<p class="mb-1">' . $this->t($this->user->getGender()) . ' ' . $this->user->getMeta('name') . '</p>';
            }

            if ($this->user->getMeta('gender') && $this->user->getMeta('name') && $this->user->getMeta('firstname')) {
                echo '<p class="mb-1">' . $this->user->getMeta('firstname') . ' ' . $this->user->getMeta('lastname') . '</p>';
            } else if ($this->user->getMeta('firstname')) {
                echo '<p class="mb-1">' . $this->t($this->user->getGender()) . ' ' . $this->user->getMeta('firstname') . ' ' . $this->user->getMeta('lastname') .'</p>';
            }

            /* Print address */

            if ($this->user->getMeta('street')) {
                echo '<p class="mb-1">' . $this->user->getMeta('street');
                if ($this->user->getMeta('city')) {
                    echo '<br>' . $this->user->getMeta('zip') . ' ' . $this->user->getMeta('city');
                }
                echo '</p>';
            }

            /* Print member status */

            if ($this->user->getMeta('member')) {
                echo '<p class="mb-1"><span class="badge bg-primary">' . $this->t('Member') . '</span></p>';
            }

            /* Print budget */

            if ($this->user->getMeta('budget') && $this->user->getMeta('budget') > 0) {
                echo '<p class="mb-0"><span class="badge bg-success">Budget: ' . $this->user->getMeta('budget') . ' ' . $this->configManager->get('i18n.currency') . '</span></p>';
            }

            ?>
