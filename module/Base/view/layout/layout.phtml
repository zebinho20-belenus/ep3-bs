    <!-- swipe calendar with hammer.js (touch devices only, #12) -->
    <script type="text/javascript" src="<?= $this->basePath('js/controller/frontend/hammer.min.js') ?>"></script>
    <script type="text/javascript">
    var nextdateelement = document.getElementById('nextdatearrow');
    if (typeof(nextdateelement) != 'undefined' && nextdateelement != null
        && ('ontouchstart' in window || navigator.maxTouchPoints > 0)) {
        var mc = new Hammer.Manager(document.body, { touchAction: "pan-y" });
        var Swipe = new Hammer.Swipe();
        mc.add(Swipe);
        mc.on('swiperight', function () {
            if (document.querySelector('.squarebox')) return;
            document.getElementById('prevdatearrow').click();
        });
        mc.on('swipeleft', function () {
            if (document.querySelector('.squarebox')) return;
            document.getElementById('nextdatearrow').click();
        });
    }
    </script>

    <script type="text/javascript">
    if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('<?= $this->basePath('js/sw.js') ?>').then(function(reg) {
            console.log('Successfully registered service worker', reg);
        }).catch(function(err) {
            console.warn('Error whilst registering service worker', err);
        });
    }
    </script>

    <script type="text/javascript">
    /* Navbar tooltips - only show when text labels are hidden (lg screens: 992-1199px) */
    (function() {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('.navbar [data-bs-toggle="tooltip"]'));
        var tooltipList = [];

        function initTooltips() {
            // Dispose existing tooltips
            tooltipList.forEach(function(tooltip) {
                tooltip.dispose();
            });
            tooltipList = [];

            // Only enable tooltips on lg screens (where text is hidden)
            var isLgScreen = window.matchMedia('(min-width: 992px) and (max-width: 1199px)').matches;

            if (isLgScreen) {
                tooltipList = tooltipTriggerList.map(function(tooltipTriggerEl) {
                    return new bootstrap.Tooltip(tooltipTriggerEl, {
                        trigger: 'hover focus'
                    });
                });
            }
        }

        // Initialize on page load
        initTooltips();

        // Re-initialize on window resize
        var resizeTimeout;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(initTooltips, 150);
        });
    })();
    </script>

