<?php

$this->setup(array(
    'title' => 'Booking-Administration',
    'panel' => 'centered-panel',
    'back' => true,
));

$reservations = $this->reservations;

$reservation = current($reservations);
$booking = $reservation->getExtra('booking');

?>

<div class="padded centered-text">
    <p><?= $this->t('This booking consists of multiple reservations:') ?></p>

    <div class="sandbox" style="margin-bottom: 16px; text-align: left;">
        <?php
        // All reservations loaded by editModeAction
        $allReservations = $this->allReservations ?? $reservations;

        $activeCount = 0;
        $cancelledCount = 0;
        foreach ($allReservations as $res):
            $isCancelled = ($res->get('status', 'confirmed') == 'cancelled');
            if ($isCancelled) { $cancelledCount++; } else { $activeCount++; }
            $dayName = $this->dateFormat(new \DateTime($res->get('date')), IntlDateFormatter::RELATIVE_SHORT);
            $time = substr($res->get('time_start'), 0, 5) . ' - ' . substr($res->get('time_end'), 0, 5);
        ?>
            <div style="padding: 2px 8px; <?= $isCancelled ? 'color: #999; text-decoration: line-through;' : '' ?>">
                <?= date('d.m.Y', strtotime($res->get('date'))) ?> &nbsp; <?= $time ?> Uhr
                <?php if ($isCancelled): ?>
                    <span style="text-decoration: none; color: #DC2626; font-size: 0.85em;">&larr; <?= $this->t('cancelled') ?></span>
                <?php endif; ?>
            </div>
        <?php endforeach; ?>

        <?php if ($cancelledCount > 0): ?>
            <div style="margin-top: 6px; font-size: 0.85em; color: #666;">
                <?= sprintf($this->t('%s active, %s cancelled'), $activeCount, $cancelledCount) ?>
            </div>
        <?php endif; ?>
    </div>

    <p><?= $this->t('What do you want to edit?') ?></p>

    <div class="sandbox">
        <a href="<?= $this->url('backend/booking/edit', [], ['query' => array_merge($this->query, ['em' => 'reservation'])]) ?>" class="default-button squarebox-internal-link">
            <span class="symbolic symbolic-booking"><?= $this->t('Only this one reservation') ?></span>
        </a>
        &nbsp;
        
        <a href="<?= $this->url('backend/booking/edit', [], ['query' => array_merge($this->query, ['em' => 'booking'])]) ?>" class="default-button squarebox-internal-link">
            <span class="symbolic symbolic-booking"><?= $this->t('The entire booking') ?></span>
        </a>
    </div>
</div>
