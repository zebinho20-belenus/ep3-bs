<?php

if ($this->booking && $this->booking->get('status') == 'cancelled') {
    $messages = ['info' => 'This booking has been cancelled'];
} else {
    $messages = [];
}

$this->setup(array(
    'title' => 'Booking-Administration',
    'panel' => 'centered-panel large-sized',
    'messages' => $messages,
    'back' => array('Booking-Administration' => $this->url('backend/booking')),
    'links' => array(
        'Calendar' => $this->url('frontend'),
        'User-Administration' => $this->url('backend/user'),
        'Configuration' => $this->url('backend/config'),
    ),
));

?>

<div class="py-3">
    <?php if ($this->conflicts): ?>
    <div class="alert alert-warning mb-3">
        <h6 class="alert-heading">
            <span class="symbolic symbolic-warning"><?= $this->t('Booking conflict detected') ?></span>
        </h6>
        <p class="mb-2"><?= $this->t('The following bookings already exist at this time:') ?></p>
        <table class="table table-sm table-bordered mb-2 bg-white">
            <thead>
                <tr>
                    <th><?= $this->t('Name') ?></th>
                    <th><?= $this->t('Date') ?></th>
                    <th><?= $this->t('Time') ?></th>
                    <th><?= $this->t('Court') ?></th>
                    <th><?= $this->t('Type') ?></th>
                </tr>
            </thead>
            <tbody>
            <?php foreach ($this->conflicts as $conflict): ?>
                <tr>
                    <td><strong><?= $this->escapeHtml($conflict['user']) ?></strong></td>
                    <td><?= $conflict['date'] ?></td>
                    <td><?= $conflict['time'] ?></td>
                    <td><?= $this->escapeHtml($conflict['square']) ?></td>
                    <td>
                        <span class="badge bg-<?= $conflict['status'] == 'subscription' ? 'primary' : 'secondary' ?>">
                            <?= $this->t(ucfirst($conflict['status'])) ?>
                        </span>
                    </td>
                </tr>
            <?php endforeach; ?>
            </tbody>
        </table>
        <p class="mb-0 small">
            <strong><?= $this->t('Click "Save" again to create the booking anyway.') ?></strong>
        </p>
    </div>
    <?php endif; ?>

    <?php

    $form = $this->editForm;
    $form->setAttribute('method', 'post');
    $form->setAttribute('action', $this->url('backend/booking/edit', [], ['query' => ['em' => $this->editMode]]));
    $form->prepare();

    ?>

    <?= $this->form()->openTag($form) ?>
    <?= $this->csrfToken() ?>

    <?= $this->formElement($form->get('bf-rid')) ?>
    <?= $this->formElement($form->get('bf-force-create')) ?>

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="sandbox">
                <?= $this->formRowCompact($form, 'bf-user') ?>

                <?php if ($this->booking && $this->booking->getExtra('user')): ?>
                    <?php $user = $this->booking->getExtra('user') ?>

                    <div class="default-form-notes">
                        <div><?= $this->t('Status') ?>: <?= $this->t($user->getStatus()) ?></div>

                        <?php if ($user->getMeta('member') !== null): ?>
                            <div><?= $this->t('Membership') ?>: <?= $user->getMeta('member') == 1 ? $this->t('Member') : $this->t('Non-member') ?></div>
                        <?php endif; ?>

                        <?php if ($user->get('email')): ?>
                            <div><?= $this->t('Email') ?>: <?= $this->escapeHtml($user->get('email')) ?></div>
                        <?php endif; ?>

                        <?php if ($user->getMeta('phone')): ?>
                            <div><?= $this->t('Phone') ?>: <?= $this->escapeHtml($user->getMeta('phone')) ?></div>
                        <?php endif; ?>

                        <?php if ($this->sessionUser->can('admin.user')): ?>
                            <div class="mt-2">
                                <a href="<?= $this->url('backend/user/edit', ['uid' => $user->need('uid')]) ?>" class="gray">
                                    <span class="symbolic symbolic-edit"><?= $this->t('Edit user') ?></span>
                                </a>
                            </div>
                        <?php endif; ?>
                    </div>
                <?php elseif ($this->sessionUser->can('admin.user')): ?>
                    <div class="mt-2">
                        <div>
                            <label class="small-text gray">
                                <input type="checkbox" name="bf-edit-user"> <?= $this->t('Edit user once saved') ?>
                            </label>
                        </div>

                        <div>
                            <label class="small-text gray">
                                <input type="checkbox" name="bf-edit-bills"> <?= $this->t('Edit booking bills once saved') ?>
                            </label>
                        </div>
                    </div>
                <?php endif; ?>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="sandbox">
                <div class="row">
                    <div class="col-6">
                        <?= $this->formRowCompact($form, 'bf-time-start') ?>
                        <?= $this->formRowCompact($form, 'bf-date-start') ?>
                    </div>
                    <div class="col-6">
                        <?= $this->formRowCompact($form, 'bf-time-end') ?>
                        <?= $this->formRowCompact($form, 'bf-date-end') ?>
                    </div>
                </div>

                <?= $this->formRowCompact($form, 'bf-repeat') ?>

                <?php if ($this->booking && $this->booking->get('status') == 'subscription' && $this->editMode == 'booking'): ?>
                    <?php if ($this->sessionUser->can(['calendar.create-subscription-bookings', 'calendar.cancel-subscription-bookings', 'calendar.delete-subscription-bookings'])): ?>
                    <div class="text-center small-text gray mt-3" style="font-style: italic;">
                        <a href="<?= $this->url('backend/booking/edit/range', ['bid' => $this->booking->need('bid')]) ?>" class="unlined symbolic symbolic-edit squarebox-internal-link">
                            <?= $this->t('Edit time or date range') ?>
                        </a>
                    </div>
                    <?php endif; ?>
                <?php endif; ?>
            </div>
        </div>

        <?php if ($this->booking && $this->booking->get('status') == 'subscription'
                 && $this->editMode == 'booking' && $this->allReservations): ?>
        <div class="col-12 mb-3">
            <div class="sandbox">
                <div class="mb-2"><strong><?= $this->t('Reservations') ?></strong></div>
                <table class="table table-sm table-bordered mb-0">
                    <thead>
                        <tr>
                            <th><?= $this->t('Date') ?></th>
                            <th><?= $this->t('Day') ?></th>
                            <th><?= $this->t('Time') ?></th>
                            <th><?= $this->t('Status') ?></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    <?php foreach ($this->allReservations as $res): ?>
                        <?php $isCancelled = ($res->get('status', 'confirmed') == 'cancelled'); ?>
                        <tr class="<?= $isCancelled ? 'table-danger' : '' ?>">
                            <td><?= date('d.m.Y', strtotime($res->get('date'))) ?></td>
                            <td><?= $this->dateFormat(new \DateTime($res->get('date')), \IntlDateFormatter::FULL, \IntlDateFormatter::NONE) ?></td>
                            <td><?= substr($res->get('time_start'), 0, 5) ?> - <?= substr($res->get('time_end'), 0, 5) ?></td>
                            <td>
                                <?php if ($isCancelled): ?>
                                    <span class="badge bg-danger"><?= $this->t('Cancelled') ?></span>
                                <?php else: ?>
                                    <span class="badge bg-success"><?= $this->t('Confirmed') ?></span>
                                <?php endif; ?>
                            </td>
                            <td class="text-end">
                                <?php if (!$isCancelled): ?>
                                    <a href="<?= $this->url('backend/booking/delete', ['rid' => $res->get('rid')], ['query' => ['edit-mode' => 'reservation']]) ?>" class="symbolic symbolic-cross gray small squarebox-internal-link" title="<?= $this->t('Cancel reservation') ?>"></a>
                                <?php endif; ?>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                    </tbody>
                </table>
                <div class="small text-muted mt-1">
                    <?php
                    $total = count($this->allReservations);
                    $cancelled = 0;
                    foreach ($this->allReservations as $r) {
                        if ($r->get('status', 'confirmed') == 'cancelled') $cancelled++;
                    }
                    ?>
                    <?= sprintf($this->t('%s reservations total, %s active, %s cancelled'), $total, $total - $cancelled, $cancelled) ?>
                </div>
            </div>
        </div>
        <?php endif; ?>

        <div class="col-md-6 mb-3">
            <div class="sandbox">
                <?= $this->formRowCompact($form, 'bf-sid') ?>
                <?= $this->formRowCompact($form, 'bf-status-billing') ?>
                <?= $this->formRowCompact($form, 'bf-quantity') ?>

                <!-- Player names (JS shows when quantity > 1) -->
                <div id="bf-player-names-container" style="display: none;">
                    <hr class="my-2">
                    <div class="small text-muted mb-1"><?= $this->t('Player names') ?></div>
                    <?php for ($i = 2; $i <= 4; $i++): ?>
                        <div class="bf-player-name-row mb-1" data-player="<?= $i ?>" style="display: none;">
                            <input type="text" name="bf-player-name-<?= $i ?>"
                                   id="bf-player-name-<?= $i ?>"
                                   placeholder="<?= $i ?>. <?= $this->t('Player\'s name') ?>"
                                   value="<?= $this->escapeHtml($this->playerNames[$i] ?? '') ?>"
                                   class="form-control form-control-sm">
                        </div>
                    <?php endfor; ?>
                </div>

                <!-- Guest checkbox (JS shows when quantity > 1) -->
                <div id="bf-guest-player-container" style="display: none;">
                    <?= $this->formRowCheckbox($form, 'bf-guest-player') ?>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="sandbox">
                <?= $this->formRowCompact($form, 'bf-notes') ?>

                <?php if ($this->booking): ?>
                    <div class="default-form-notes">
                        <div class="separator-small separator-line"></div>

                        <?= $this->t('Bill') ?>:

                        <?php if ($this->billTotal !== null): ?>
                            <strong><?= number_format($this->billTotal / 100, 2, ',', '.') ?> €</strong>
                        <?php endif; ?>

                        &nbsp;
                        <a href="<?= $this->url('user/bookings/bills', ['bid' => $this->booking->get('bid')]) ?>" class="symbolic symbolic-info unlined gray"><?= $this->t('View') ?></a>

                        <?php if ($this->sessionUser->can('admin.booking')): ?>
                            &nbsp;
                            <a href="<?= $this->url('backend/booking/bills', ['bid' => $this->booking->get('bid')]) ?>" class="symbolic symbolic-edit unlined gray"><?= $this->t('Edit') ?></a>
                        <?php endif; ?>
                    </div>

                    <div class="default-form-notes">
                        <div class="separator-small separator-line"></div>

                        <?php if ($this->booking->getMeta('creator')): ?>
                            <?= sprintf($this->t('Booking created:<br>%s by %s'),
                                $this->prettyDate(new \DateTime($this->booking->get('created'))),
                                $this->booking->getMeta('creator')) ?>
                        <?php else: ?>
                            <?= sprintf($this->t('Booking created:<br>%s'),
                                $this->prettyDate(new \DateTime($this->booking->get('created')))) ?>
                        <?php endif; ?>

                        <?php if ($this->booking->getMeta('cancellor') && $this->booking->getMeta('cancelled')): ?>
                            <br>

                            <?= sprintf($this->t('Booking cancelled:<br>%s by %s'),
                                $this->prettyDate(new \DateTime($this->booking->getMeta('cancelled'))),
                                $this->booking->getMeta('cancellor')) ?>
                        <?php endif; ?>
                    </div>
                <?php endif; ?>
            </div>
        </div>
    </div>

    <div class="edit-actions">
        <?php if ($this->sessionUser->can('admin.booking')): ?>
            <?= $this->formElement($form->get('bf-submit')) ?>
        <?php endif; ?>

        <?php if ($this->booking && $this->booking->get('status') == 'cancelled' && $this->sessionUser->can('calendar.reactivate-bookings')): ?>
            <button type="submit" name="bf-reactivate" value="1" class="default-button">
                <span class="symbolic symbolic-reload"><?= $this->t('Reactivate') ?></span>
            </button>
        <?php endif; ?>

        <?php if ($this->reservation): ?>
            <?php if ($this->booking && $this->booking->get('status') != 'cancelled'): ?>
                <?php if ($this->sessionUser->can(['admin.booking', 'calendar.cancel-single-bookings', 'calendar.cancel-subscription-bookings'])): ?>
                    <a href="<?= $this->url('backend/booking/delete', ['rid' => $this->reservation->get('rid')], ['query' => ['edit-mode' => $this->editMode]]) ?>" class="default-button default-button-danger squarebox-internal-link">
                        <span class="symbolic symbolic-cross"><?= $this->t('Cancel booking') ?></span>
                    </a>
                <?php endif; ?>
            <?php else: ?>
                <?php if ($this->sessionUser->can(['admin.booking', 'calendar.delete-single-bookings', 'calendar.delete-subscription-bookings'])): ?>
                    <a href="<?= $this->url('backend/booking/delete', ['rid' => $this->reservation->get('rid')], ['query' => ['edit-mode' => $this->editMode]]) ?>" class="default-button default-button-danger squarebox-internal-link">
                        <span class="symbolic symbolic-cross"><?= $this->t('Delete') ?></span>
                    </a>
                <?php endif; ?>
            <?php endif; ?>

        <?php else: ?>
            <?php if ($this->sessionUser->can('admin.event')): ?>
                <a href="<?= $this->url('backend/event/edit', [], ['query' => ['ds' => $this->query['ds'], 'ts' => $this->query['ts'], 'te' => $this->query['te'], 's' => $this->query['s']]]) ?>" class="default-button default-button-outline">
                    <span class="symbolic symbolic-date"><?= $this->t('New event') ?></span>
                </a>
            <?php endif; ?>
        <?php endif; ?>
    </div>

    <?= $this->form()->closeTag() ?>

    <div id="bf-url-provider"
         data-user-autocomplete-url="<?= $this->url('backend/user/interpret') ?>"></div>

    <div id="bf-tag-provider"
        data-edit-mode-tag="<?= $this->editMode ?>"></div>
</div>

