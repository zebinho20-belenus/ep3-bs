<?php

$this->setup(array(
    'title' => 'Booking-Administration',
    'panel' => 'centered-panel giant-sized',
    'back' => array('Calendar' => $this->url('frontend')),
    'links' => array(
        'User-Administration' => $this->url('backend/user'),
        'Event-Administration' => $this->url('backend/event'),
        'Configuration' => $this->url('backend/config'),
    ),
));

?>

<div>
    <h1><?= $this->t('Booking-Administration') ?></h1>

    <div class="separator-small"></div>

    <p><?= $this->t('Here you can create, edit or delete the bookings of your system.') ?></p>

    <div class="separator separator-line"></div>

    <?= $this->partial('backend/booking/index.datepicker.phtml', ['dateStart' => $this->dateStart, 'dateEnd' => $this->dateEnd, 'search' => $this->search]) ?>

    <div class="separator separator-line"></div>

    <?php
    // Build pagination URL helper
    $paginationQuery = [];
    if ($this->dateStart) { $paginationQuery['date-start'] = $this->dateStart->format('d.m.Y'); }
    if ($this->dateEnd) { $paginationQuery['date-end'] = $this->dateEnd->format('d.m.Y'); }
    if ($this->search) { $paginationQuery['search'] = $this->search; }
    if (isset($_GET['all-dates']) && $_GET['all-dates'] === '1') { $paginationQuery['all-dates'] = '1'; }
    $page = $this->page ?? 1;
    $totalPages = $this->totalPages ?? 1;
    $totalCount = $this->totalCount ?? 0;
    $pageSize = $this->pageSize ?? 25;
    if ($pageSize != 25) { $paginationQuery['per-page'] = $pageSize; }
    ?>

    <?php if ($totalCount > 0): ?>
    <div class="d-flex justify-content-between align-items-center no-print" style="padding: 8px 0;">
        <small class="text-muted">
            <?= sprintf($this->t('%s results, page %s of %s'), $totalCount, $page, $totalPages) ?>
        </small>
        <div class="d-flex align-items-center gap-2">
            <select class="form-select form-select-sm" style="width: auto;" onchange="window.location.href=this.value">
                <?php foreach ([25, 50, 100] as $size): ?>
                    <option value="<?= $this->url('backend/booking', [], ['query' => array_merge($paginationQuery, ['per-page' => $size, 'page' => 1])]) ?>"
                        <?= $size == $pageSize ? 'selected' : '' ?>><?= $size ?> / <?= $this->t('Page') ?></option>
                <?php endforeach; ?>
            </select>
            <?php if ($totalPages > 1): ?>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <?php if ($page > 1): ?>
                        <li class="page-item">
                            <a class="page-link" href="<?= $this->url('backend/booking', [], ['query' => array_merge($paginationQuery, ['page' => $page - 1])]) ?>">&laquo;</a>
                        </li>
                    <?php else: ?>
                        <li class="page-item disabled"><span class="page-link">&laquo;</span></li>
                    <?php endif; ?>

                    <?php
                    $rangeStart = max(1, $page - 3);
                    $rangeEnd = min($totalPages, $page + 3);
                    if ($rangeStart > 1): ?>
                        <li class="page-item"><a class="page-link" href="<?= $this->url('backend/booking', [], ['query' => array_merge($paginationQuery, ['page' => 1])]) ?>">1</a></li>
                        <?php if ($rangeStart > 2): ?><li class="page-item disabled"><span class="page-link">&hellip;</span></li><?php endif; ?>
                    <?php endif; ?>

                    <?php for ($i = $rangeStart; $i <= $rangeEnd; $i++): ?>
                        <li class="page-item <?= $i == $page ? 'active' : '' ?>">
                            <a class="page-link" href="<?= $this->url('backend/booking', [], ['query' => array_merge($paginationQuery, ['page' => $i])]) ?>"><?= $i ?></a>
                        </li>
                    <?php endfor; ?>

                    <?php if ($rangeEnd < $totalPages): ?>
                        <?php if ($rangeEnd < $totalPages - 1): ?><li class="page-item disabled"><span class="page-link">&hellip;</span></li><?php endif; ?>
                        <li class="page-item"><a class="page-link" href="<?= $this->url('backend/booking', [], ['query' => array_merge($paginationQuery, ['page' => $totalPages])]) ?>"><?= $totalPages ?></a></li>
                    <?php endif; ?>

                    <?php if ($page < $totalPages): ?>
                        <li class="page-item">
                            <a class="page-link" href="<?= $this->url('backend/booking', [], ['query' => array_merge($paginationQuery, ['page' => $page + 1])]) ?>">&raquo;</a>
                        </li>
                    <?php else: ?>
                        <li class="page-item disabled"><span class="page-link">&raquo;</span></li>
                    <?php endif; ?>
                </ul>
            </nav>
            <?php endif; ?>
        </div>
    </div>
    <?php endif; ?>

    <div class="centered-text" style="padding: 16px 0px 16px 0px;">

        <?php if ($this->reservations): ?>

            <form method="post" action="<?= $this->url('backend/booking/bulk') ?>" id="bulk-form">
                <?= $this->csrfToken() ?>

                <?= $this->backendBookingsFormat($this->reservations, $this->dateStart, $this->dateEnd, $this->search) ?>

                <div class="edit-actions no-print" id="bulk-actions" style="display: none;">
                    <?php if ($this->sessionUser && $this->sessionUser->can('calendar.reactivate-bookings')): ?>
                        <button type="submit" name="bulk-action" value="reactivate"
                            class="default-button" id="bulk-reactivate-btn" style="display: none;">
                            <span class="symbolic symbolic-reload"><?= $this->t('Reactivate selected bookings') ?></span>
                        </button>
                    <?php endif; ?>

                    <button type="submit" name="bulk-action" value="cancel"
                        class="default-button default-button-danger" id="bulk-cancel-btn">
                        <span class="symbolic symbolic-cross"><?= $this->t('Cancel selected bookings') ?></span>
                    </button>

                    <?php if ($this->sessionUser && $this->sessionUser->can('admin.all')): ?>
                        <button type="submit" name="bulk-action" value="delete"
                            class="default-button default-button-danger" id="bulk-delete-btn">
                            <span class="symbolic symbolic-cross"><?= $this->t('Delete selected bookings') ?></span>
                        </button>
                    <?php endif; ?>
                </div>

            </form>

        <?php else: ?>

            <?php if ($this->dateStart || $this->dateEnd): ?>
                <p><span class="red"><?= sprintf($this->t('%sNo bookings found%s for this search'), '<b>', '</b>') ?></span></p>
            <?php endif; ?>

            <p><a href="<?= $this->url('backend/booking/edit', [], ['query' => ['force' => 'new']]) ?>" class="unlined gray"><span class="symbolic symbolic-plus"><?= $this->t('New booking') ?></span></a></p>

        <?php endif; ?>

    </div>

    <?php if ($totalPages > 1 && $this->reservations): ?>
    <div class="d-flex justify-content-end no-print" style="padding: 0 0 16px 0;">
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <?php if ($page > 1): ?>
                    <li class="page-item">
                        <a class="page-link" href="<?= $this->url('backend/booking', [], ['query' => array_merge($paginationQuery, ['page' => $page - 1])]) ?>">&laquo;</a>
                    </li>
                <?php endif; ?>
                <li class="page-item disabled"><span class="page-link"><?= $page ?> / <?= $totalPages ?></span></li>
                <?php if ($page < $totalPages): ?>
                    <li class="page-item">
                        <a class="page-link" href="<?= $this->url('backend/booking', [], ['query' => array_merge($paginationQuery, ['page' => $page + 1])]) ?>">&raquo;</a>
                    </li>
                <?php endif; ?>
            </ul>
        </nav>
    </div>
    <?php endif; ?>

</div>
