<?php

$this->setup(array(
    'title' => 'Booking-Administration',
    'panel' => 'centered-panel giant-sized',
    'back' => array('Calendar' => $this->url('frontend')),
    'links' => array(
        'User-Administration' => $this->url('backend/user'),
        'Event-Administration' => $this->url('backend/event'),
        'Configuration' => $this->url('backend/config'),
    ),
));

?>

<div>
    <h1><?= $this->t('Booking-Administration') ?></h1>

    <div class="separator-small"></div>

    <p><?= $this->t('Here you can create, edit or delete the bookings of your system.') ?></p>

    <div class="separator separator-line"></div>

    <?= $this->partial('backend/booking/index.datepicker.phtml', ['dateStart' => $this->dateStart, 'dateEnd' => $this->dateEnd, 'search' => $this->search]) ?>

    <div class="separator separator-line"></div>

    <div class="centered-text" style="padding: 16px 0px 16px 0px;">

        <?php if ($this->reservations): ?>

            <form method="post" action="<?= $this->url('backend/booking/bulk') ?>" id="bulk-form">
                <?= $this->csrfToken() ?>

                <?= $this->backendBookingsFormat($this->reservations, $this->dateStart, $this->dateEnd, $this->search) ?>

                <div class="edit-actions no-print" id="bulk-actions" style="display: none;">
                    <button type="submit" name="bulk-action" value="reactivate"
                        class="default-button" id="bulk-reactivate-btn" style="display: none;">
                        <span class="symbolic symbolic-reload"><?= $this->t('Reactivate selected bookings') ?></span>
                    </button>

                    <button type="submit" name="bulk-action" value="cancel"
                        class="default-button default-button-danger" id="bulk-cancel-btn">
                        <span class="symbolic symbolic-cross"><?= $this->t('Cancel selected bookings') ?></span>
                    </button>

                    <?php if ($this->sessionUser && $this->sessionUser->can('admin.all')): ?>
                        <button type="submit" name="bulk-action" value="delete"
                            class="default-button default-button-danger" id="bulk-delete-btn">
                            <span class="symbolic symbolic-cross"><?= $this->t('Delete selected bookings') ?></span>
                        </button>
                    <?php endif; ?>
                </div>

            </form>

        <?php else: ?>

            <?php if ($this->dateStart || $this->dateEnd): ?>
                <p><span class="red"><?= sprintf($this->t('%sNo bookings found%s for this search'), '<b>', '</b>') ?></span></p>
            <?php endif; ?>

            <p><a href="<?= $this->url('backend/booking/edit', [], ['query' => ['force' => 'new']]) ?>" class="unlined gray"><span class="symbolic symbolic-plus"><?= $this->t('New booking') ?></span></a></p>

        <?php endif; ?>

    </div>
</div>
