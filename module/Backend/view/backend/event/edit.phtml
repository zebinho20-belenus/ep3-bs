<?php

if ($this->event) {
    $eid = $this->event->need('eid');
} else {
    $eid = null;
}

$this->setup(array(
    'title' => 'Event-Administration',
    'panel' => 'centered-panel',
    'back' => array(
        'Event-Administration' => $this->url('backend/event'),
    ),
    'links' => array(
        'User-Administration' => $this->url('backend/user'),
        'Booking-Administration' => $this->url('backend/booking'),
        'Configuration' => $this->url('backend/config'),
    ),
));

$this->headScript()->appendFile($this->basePath('js/tinymce/tinymce.min.js'));
$this->headScript()->appendFile($this->basePath('js/tinymce/tinymce.setup.medium.js'));

?>

<div>
    <h1><?= $this->t('Event-Administration') ?></h1>

    <div class="separator-small"></div>

    <?= $this->backendInfo('i18n') ?>

    <div class="separator separator-line"></div>

    <?php if (isset($this->conflicts) && $this->conflicts): ?>
    <div class="alert alert-warning mt-3 mb-0">
        <strong><?= $this->t('The following conflicts were found:') ?></strong>
        <table class="table table-sm table-bordered mt-2 mb-0 bg-white">
            <thead>
                <tr>
                    <th><?= $this->t('Type') ?></th>
                    <th><?= $this->t('Name') ?></th>
                    <th><?= $this->t('Square') ?></th>
                    <th><?= $this->t('Date') ?></th>
                    <th><?= $this->t('Time') ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($this->conflicts as $conflict): ?>
                <tr>
                    <td><?= $this->t($conflict['type'] === 'booking' ? 'Existing booking' : 'Existing event') ?></td>
                    <td><?= $this->escapeHtml($conflict['name']) ?></td>
                    <td><?= $this->escapeHtml($conflict['square']) ?></td>
                    <td><?= $this->escapeHtml($conflict['date']) ?></td>
                    <td><?= $this->escapeHtml($conflict['time']) ?></td>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>
    <?php endif; ?>

    <div class="py-3">
        <?php

        $form = $this->editForm;
        $form->setAttribute('method', 'post');
        $form->setAttribute('action', $this->url('backend/event/edit', ['eid' => $eid]));
        $form->prepare();

        $hasConflicts = isset($this->conflicts) && $this->conflicts;

        ?>

        <?= $this->form()->openTag($form) ?>

        <?= $this->formRowDefault($form, 'ef-name') ?>
        <?= $this->formRowDefault($form, 'ef-description') ?>

        <div class="row">
            <div class="col-md-6">
                <?= $this->formRowDefault($form, 'ef-date-start') ?>
                <?= $this->formRowDefault($form, 'ef-time-start') ?>
            </div>
            <div class="col-md-6">
                <?= $this->formRowDefault($form, 'ef-date-end') ?>
                <?= $this->formRowDefault($form, 'ef-time-end') ?>
            </div>
        </div>

        <?php if ($eid): ?>
            <?= $this->formRowDefault($form, 'ef-sid') ?>
        <?php else: ?>
            <div class="sandbox mb-3">
                <div class="row">
                    <div class="col-md-6">
                        <?= $this->formRowDefault($form, 'ef-sid-from') ?>
                    </div>
                    <div class="col-md-6">
                        <?= $this->formRowDefault($form, 'ef-sid-to') ?>
                    </div>
                </div>
                <?= $this->formRowDefault($form, 'ef-repeat') ?>
            </div>
        <?php endif; ?>

        <?= $this->formRowDefault($form, 'ef-capacity') ?>
        <?= $this->formRowDefault($form, 'ef-notes') ?>

        <?= $this->formHidden($form->get('ef-force')) ?>

        <?php if ($hasConflicts): ?>
            <?php $form->get('ef-submit')->setValue($this->t('Create anyway')); ?>
        <?php endif; ?>

        <div class="edit-actions">
            <?= $this->formElement($form->get('ef-submit')) ?>

            <?php if ($this->event): ?>
                <a href="<?= $this->url('backend/event/delete', ['eid' => $eid]) ?>" class="default-button default-button-danger">
                    <span class="symbolic symbolic-cross"><?= $this->t('Delete') ?></span>
                </a>
            <?php endif; ?>
        </div>

        <?= $this->form()->closeTag() ?>
    </div>
</div>

<?php
$js = <<<'JSEOF'
$(function() {
    var $ds = $("#ef-date-start"), $de = $("#ef-date-end");

    $ds.on("change", function() {
        try {
            var fmt = $ds.datepicker("option", "dateFormat") || "dd.mm.yy";
            var s = $.datepicker.parseDate(fmt, $ds.val());
            var e = $.datepicker.parseDate(fmt, $de.val());
            if (s && (!e || s > e)) { $de.val($ds.val()); }
        } catch(x) {}
    });
JSEOF;

if (! $eid) {
    $js .= <<<'JSEOF'

    var $f = $("#ef-sid-from"), $t = $("#ef-sid-to");
    function tog() {
        if ($f.val() === "null") { $t.val("null").prop("disabled", true); }
        else { $t.prop("disabled", false); }
    }
    $f.on("change", tog);
    tog();
    $f.closest("form").on("submit", function() { $t.prop("disabled", false); });
JSEOF;
}

$js .= "\n});";

$this->headScript()->appendScript($js);
?>
