<?php

$this->setup(array(
    'title' => 'Behaviour',
    'panel' => 'centered-panel large-sized',
    'back' => array(
        'Configuration' => $this->url('backend/config'),
    ),
));

$this->headScript()->appendFile($this->basePath('js/controller/backend/config/behaviour.min.js'));

?>

<div>
    <h1><?= $this->t('Behaviour') ?></h1>

    <div class="separator-small"></div>

    <p><?= $this->t('How does registration work? How many days are displayed in the calendar?') ?></p>

    <?= $this->backendInfo('i18n') ?>

    <div class="separator separator-line"></div>

    <div class="py-3">
        <?php

        $form = $this->behaviourForm;
        $form->setAttribute('method', 'post');
        $form->setAttribute('action', $this->url('backend/config/behaviour'));
        $form->prepare();

        ?>

        <?= $this->form()->openTag($form) ?>
        <?= $this->csrfToken() ?>

        <?= $this->formRowDefault($form, 'cf-maintenance') ?>
        <?= $this->formRowDefault($form, 'cf-maintenance-message') ?>
        <?= $this->formRowDefault($form, 'cf-registration') ?>
        <?= $this->formRowDefault($form, 'cf-registration-message') ?>
        <?= $this->formRowDefault($form, 'cf-activation') ?>
        <?= $this->formRowDefault($form, 'cf-calendar-days') ?>
        <?= $this->formRowDefault($form, 'cf-calendar-day-exceptions') ?>
        <?= $this->formRowDefault($form, 'cf-calendar-club-exceptions') ?>
        <?= $this->formRowDefault($form, 'cf-calendar-display-club-exceptions') ?>

        <div class="separator separator-line"></div>

        <h3 class="mb-3"><?= $this->t('Email notifications') ?></h3>
        <?= $this->formRowDefault($form, 'cf-no-email-statuses') ?>
        <div class="mb-3" style="margin-top: -0.5rem;">
            <small class="text-muted"><?= $this->t('Click to add/remove:') ?></small><br>
            <?php
            $noEmailStatuses = array_map('trim', explode(',', $form->get('cf-no-email-statuses')->getValue() ?: ''));
            $statusMap = [
                'team' => $this->t('Team'),
                'guestgroup' => $this->t('Guest Group'),
                'singleguest' => $this->t('Single Guest'),
                'placeholder' => $this->t('Placeholder'),
                'blocked' => $this->t('Blocked user'),
                'deleted' => $this->t('Deleted user'),
            ];
            foreach ($statusMap as $slug => $label):
                $isActive = in_array($slug, $noEmailStatuses);
            ?>
                <span class="badge <?= $isActive ? 'bg-primary' : 'bg-light text-dark border' ?> me-1 mb-1"
                      style="cursor: pointer; font-size: 0.8rem;"
                      onclick="(function(el,slug){var input=document.getElementById('cf-no-email-statuses');var vals=input.value.split(',').map(function(s){return s.trim()}).filter(Boolean);var idx=vals.indexOf(slug);if(idx>-1){vals.splice(idx,1);el.className='badge bg-light text-dark border me-1 mb-1'}else{vals.push(slug);el.className='badge bg-primary me-1 mb-1'}input.value=vals.join(', ')})(this,'<?= $slug ?>')"
                ><?= $this->escapeHtml($slug) ?> <small>(<?= $this->escapeHtml($label) ?>)</small></span>
            <?php endforeach; ?>
        </div>

        <hr class="my-3">

        <h3 class="mb-3"><?= $this->t('Audit-Log') ?></h3>
        <?= $this->formRowDefault($form, 'cf-audit-retention-days') ?>

        <hr class="my-3">

        <div class="d-flex flex-wrap gap-2 mb-3">
            <a href="<?= $this->url('backend/config/behaviour/rules') ?>" class="default-button default-button-outline">
                <span class="symbolic symbolic-edit"><?= $this->t('Edit business terms and privacy policy') ?></span>
            </a>
            <a href="<?= $this->url('backend/config/behaviour/status-colors') ?>" class="default-button default-button-outline">
                <span class="symbolic symbolic-edit"><?= $this->t('Edit billing status names and colors') ?></span>
            </a>
        </div>

        <div class="edit-actions">
            <?= $this->formElement($form->get('cf-submit')) ?>
        </div>

        <?= $this->form()->closeTag() ?>
    </div>
</div>
