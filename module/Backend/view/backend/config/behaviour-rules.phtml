<?php

$this->setup(array(
    'title' => 'Edit business terms and privacy policy',
    'panel' => 'centered-panel large-sized',
    'back' => array(
        'Behaviour' => $this->url('backend/config/behaviour'),
    ),
));

?>

<div>
    <h1><?= $this->t('Edit business terms and privacy policy') ?></h1>

    <div class="separator-small"></div>

    <?= $this->backendInfo('i18n') ?>

    <div class="separator separator-line"></div>

    <div class="py-3">
        <?php

        $form = $this->rulesForm;
        $form->setAttribute('method', 'post');
        $form->setAttribute('action', $this->url('backend/config/behaviour/rules'));
        $form->prepare();

        ?>

        <?= $this->form()->openTag($form) ?>
        <?= $this->csrfToken() ?>

        <?= $this->formRowDefault($form, 'cf-terms-file') ?>

        <?php if ($this->option('service.user.registration.terms.file')): ?>
            <div class="small text-muted mb-3">
                <?php
                $termsFile = $this->option('service.user.registration.terms.file');
                echo sprintf('%s <a href="%s" target="_blank">%s</a>',
                    $this->t('Current file:'),
                    $this->basePath($termsFile),
                    basename($termsFile));
                ?>
                <form method="post" action="<?= $this->url('backend/config/behaviour/rules') ?>" style="display: inline;">
                    <?= $this->csrfToken() ?>
                    <input type="hidden" name="delete-file" value="terms">
                    <button type="submit" class="btn btn-link p-0 ms-2 text-danger" title="<?= $this->t('Delete') ?>">(x)</button>
                </form>
            </div>
        <?php endif; ?>

        <?= $this->formRowDefault($form, 'cf-terms-name') ?>

        <?= $this->formRowDefault($form, 'cf-privacy-file') ?>

        <?php if ($this->option('service.user.registration.privacy.file')): ?>
            <div class="small text-muted mb-3">
                <?php
                $privacyFile = $this->option('service.user.registration.privacy.file');
                echo sprintf('%s <a href="%s" target="_blank">%s</a>',
                    $this->t('Current file:'),
                    $this->basePath($privacyFile),
                    basename($privacyFile));
                ?>
                <form method="post" action="<?= $this->url('backend/config/behaviour/rules') ?>" style="display: inline;">
                    <?= $this->csrfToken() ?>
                    <input type="hidden" name="delete-file" value="privacy">
                    <button type="submit" class="btn btn-link p-0 ms-2 text-danger" title="<?= $this->t('Delete') ?>">(x)</button>
                </form>
            </div>
        <?php endif; ?>

        <?= $this->formRowDefault($form, 'cf-privacy-name') ?>

        <div class="edit-actions">
            <?= $this->formElement($form->get('cf-submit')) ?>
        </div>

        <?= $this->form()->closeTag() ?>
    </div>
</div>
