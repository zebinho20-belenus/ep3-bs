<?php

$this->setup(array(
    'title' => 'Audit-Log',
    'panel' => 'centered-panel giant-sized',
    'back' => array('Configuration' => $this->url('backend/config')),
));

$categoryLabels = [
    'booking' => ['Buchung', 'primary'],
    'payment' => ['Zahlung', 'success'],
    'user' => ['Benutzer', 'warning'],
    'admin' => ['Admin', 'danger'],
    'config' => ['Konfig.', 'secondary'],
    'system' => ['System', 'dark'],
];

$pmLabels = ['paypal' => 'PayPal', 'stripe' => 'Stripe', 'klarna' => 'Klarna', 'budget' => 'Budget', 'paylater' => 'Spaeter', 'member' => 'Mitglied'];

$actionLabels = [
    'create' => 'Erstellt', 'cancel' => 'Storniert', 'delete' => 'Geloescht', 'edit' => 'Bearbeitet',
    'reactivate' => 'Reaktiviert', 'edit_bill' => 'Rechnung', 'edit_user' => 'Bearbeitet',
    'disable_user' => 'Deaktiviert', 'delete_user' => 'Geloescht',
    'create_event' => 'Erstellt', 'edit_event' => 'Bearbeitet', 'delete_event' => 'Geloescht',
    'login' => 'Login', 'login_failed' => 'Login fehlgeschl.', 'logout' => 'Logout',
    'payment_success' => 'Bezahlt', 'payment_failed' => 'Fehlgeschlagen', 'budget_refund' => 'Rueckerstattung',
    'config_change' => 'Geaendert',
];

?>

<div>
    <h1><?= $this->t('Audit-Log') ?></h1>

    <div class="separator-small"></div>

    <p class="d-none d-md-block"><?= $this->t('All system actions and changes') ?></p>

    <div class="separator separator-line d-none d-md-block"></div>

    <!-- Filter -->
    <form method="get" action="<?= $this->url('backend/audit') ?>" class="no-print mb-3">
        <div class="row g-2">
            <div class="col-6 col-md-auto">
                <input type="text" name="date-start" class="form-control form-control-sm datepicker"
                       placeholder="<?= $this->t('Date from') ?>" value="<?= $this->escapeHtml($this->dateStart) ?>">
            </div>
            <div class="col-6 col-md-auto">
                <input type="text" name="date-end" class="form-control form-control-sm datepicker"
                       placeholder="<?= $this->t('Date to') ?>" value="<?= $this->escapeHtml($this->dateEnd) ?>">
            </div>
            <div class="col-6 col-md-auto">
                <select name="category" class="form-select form-select-sm">
                    <option value=""><?= $this->t('All categories') ?></option>
                    <?php foreach ($categoryLabels as $key => $label): ?>
                        <option value="<?= $key ?>" <?= $this->category == $key ? 'selected' : '' ?>><?= $label[0] ?></option>
                    <?php endforeach; ?>
                </select>
            </div>
            <div class="col-6 col-md-auto">
                <div class="input-group input-group-sm">
                    <input type="text" name="search" class="form-control"
                           placeholder="<?= $this->t('Search') ?>" value="<?= $this->escapeHtml($this->search) ?>">
                    <button type="submit" class="btn btn-primary"><span class="fa fa-search"></span></button>
                </div>
            </div>
            <div class="col-auto d-none d-md-block">
                <a href="<?= $this->url('backend/audit') ?>" class="btn btn-sm btn-outline-secondary"><?= $this->t('Reset') ?></a>
            </div>
        </div>
    </form>

    <div class="separator separator-line"></div>

    <?php
    $page = $this->page ?? 1;
    $totalPages = $this->totalPages ?? 1;
    $totalCount = $this->totalCount ?? 0;
    $paginationQuery = [];
    if ($this->dateStart) { $paginationQuery['date-start'] = $this->dateStart; }
    if ($this->dateEnd) { $paginationQuery['date-end'] = $this->dateEnd; }
    if ($this->category) { $paginationQuery['category'] = $this->category; }
    if ($this->search) { $paginationQuery['search'] = $this->search; }
    ?>

    <?php if ($totalPages > 1): ?>
    <div class="d-flex justify-content-between align-items-center no-print" style="padding: 8px 0;">
        <small class="text-muted">
            <?= sprintf($this->t('%s results, page %s of %s'), $totalCount, $page, $totalPages) ?>
        </small>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <?php if ($page > 1): ?>
                    <li class="page-item">
                        <a class="page-link" href="<?= $this->url('backend/audit', [], ['query' => array_merge($paginationQuery, ['page' => $page - 1])]) ?>">&laquo;</a>
                    </li>
                <?php endif; ?>
                <?php
                $startPage = max(1, $page - 2);
                $endPage = min($totalPages, $page + 2);
                for ($p = $startPage; $p <= $endPage; $p++): ?>
                    <li class="page-item <?= $p == $page ? 'active' : '' ?>">
                        <a class="page-link" href="<?= $this->url('backend/audit', [], ['query' => array_merge($paginationQuery, ['page' => $p])]) ?>"><?= $p ?></a>
                    </li>
                <?php endfor; ?>
                <?php if ($page < $totalPages): ?>
                    <li class="page-item">
                        <a class="page-link" href="<?= $this->url('backend/audit', [], ['query' => array_merge($paginationQuery, ['page' => $page + 1])]) ?>">&raquo;</a>
                    </li>
                <?php endif; ?>
            </ul>
        </nav>
    </div>
    <?php endif; ?>

    <?php if (empty($this->entries)): ?>
        <p class="text-muted"><?= $this->t('No entries found') ?></p>
    <?php else: ?>

    <?php
    // Pre-process detail data for all entries
    $processedEntries = [];
    foreach ($this->entries as $i => $entry) {
        $d = $entry['detail'] ? json_decode($entry['detail'], true) : [];
        $infoParts = [];
        if (isset($d['paymentMethod']) && $d['paymentMethod']) {
            $infoParts[] = '<span class="badge bg-info text-dark">' . ($pmLabels[$d['paymentMethod']] ?? $d['paymentMethod']) . '</span>';
        }
        if (isset($d['square_name']) && $d['square_name']) {
            $infoParts[] = $this->escapeHtml($d['square_name']);
        }
        if (isset($d['user_name_full']) && $d['user_name_full']) {
            $infoParts[] = $this->escapeHtml($d['user_name_full']);
        }
        if (isset($d['player_names']) && is_array($d['player_names'])) {
            $infoParts[] = '<small class="text-muted">' . $this->escapeHtml(implode(', ', $d['player_names'])) . '</small>';
        }
        if (isset($d['budget']) && $d['budget']) {
            $infoParts[] = '<small>Budget: ' . $this->escapeHtml($d['budget']) . '&rarr;' . $this->escapeHtml($d['newbudget'] ?? '0') . '</small>';
        }
        if (isset($d['budget_old']) && isset($d['budget_new']) && $d['budget_old'] != $d['budget_new']) {
            $infoParts[] = '<small>Budget: ' . $this->escapeHtml($d['budget_old'] ?: '0') . '&rarr;' . $this->escapeHtml($d['budget_new']) . '</small>';
        }
        // Show readable changes for edit actions
        if (isset($d['changes_readable']) && is_array($d['changes_readable']) && !empty($d['changes_readable'])) {
            foreach ($d['changes_readable'] as $change) {
                $infoParts[] = '<small class="text-info">' . $this->escapeHtml($change) . '</small>';
            }
        } elseif (isset($d['changes']) && is_array($d['changes']) && !empty($d['changes'])) {
            // Fallback for old entries without changes_readable
            foreach ($d['changes'] as $key => $cv) {
                if (is_array($cv) && isset($cv['old']) && isset($cv['new'])) {
                    $infoParts[] = '<small class="text-info">' . $this->escapeHtml($key) . ': ' . $this->escapeHtml($cv['old']) . ' &rarr; ' . $this->escapeHtml($cv['new']) . '</small>';
                }
            }
        }
        // IP + Country for login events
        if ($entry['ip'] && ($entry['action'] == 'login' || $entry['action'] == 'login_failed')) {
            $ipDisplay = '<small class="text-muted"><span class="fa fa-globe"></span> ' . $this->escapeHtml($entry['ip']);
            if (isset($d['countryCode']) && $d['countryCode']) {
                $ipDisplay .= ' (' . $this->escapeHtml($d['countryCode']) . ')';
            }
            $ipDisplay .= '</small>';
            $infoParts[] = $ipDisplay;
        }
        $entry['_info'] = $infoParts ? implode(' | ', $infoParts) : '';
        $entry['_info_stacked'] = $infoParts ? implode('<br>', $infoParts) : '';
        $entry['_index'] = $i;
        $cat = $entry['category'];
        $entry['_badge'] = isset($categoryLabels[$cat]) ? $categoryLabels[$cat] : [$cat, 'secondary'];
        $entry['_action_label'] = isset($actionLabels[$entry['action']]) ? $actionLabels[$entry['action']] : $entry['action'];
        $processedEntries[] = $entry;
    }
    ?>

    <!-- Desktop: Two-line entries -->
    <style>
        .audit-entry { padding: 0.5rem 0; border-bottom: 1px solid #e9ecef; cursor: pointer; transition: background-color 0.15s; }
        .audit-entry:hover { background-color: rgba(0,0,0,0.02); }
        .audit-entry:last-child { border-bottom: none; }
        .audit-chip { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 1rem; font-size: 0.75rem; margin: 0.1rem 0.15rem; }
        .audit-chip-change { background: #e8f4fd; color: #0c5da5; }
        .audit-chip-info { background: #f0f0f0; color: #555; }
        .audit-chip-payment { background: #e6f9e6; color: #1a7a1a; }
        .audit-chip-budget { background: #fff3e0; color: #b86e00; }
    </style>
    <div class="d-none d-lg-block">
        <?php foreach ($processedEntries as $entry): $i = $entry['_index'];
            $d = $entry['detail'] ? json_decode($entry['detail'], true) : [];
            $msg = $entry['message'];
            if (isset($d['changes_readable']) && !empty($d['changes_readable'])) {
                if (($pos = strpos($msg, ' — ')) !== false) { $msg = substr($msg, 0, $pos); }
                elseif (strpos($msg, 'Uhr:') !== false) { $msg = substr($msg, 0, strpos($msg, 'Uhr:') + 3); }
            }
            $ts = strtotime($entry['created']);
            $dateStr = (date('Y', $ts) == date('Y')) ? date('d.m. H:i', $ts) : date('d.m.Y H:i', $ts);
        ?>
        <div class="audit-entry" onclick="var d=document.getElementById('detail-<?= $i ?>');if(d)d.style.display=d.style.display=='none'?'block':'none';">
            <!-- Line 1: Meta -->
            <div class="d-flex align-items-center gap-2" style="font-size: 0.82rem;">
                <span class="text-muted text-nowrap"><?= $dateStr ?></span>
                <span class="badge bg-<?= $entry['_badge'][1] ?>"><?= $entry['_badge'][0] ?></span>
                <span style="font-size: 0.78rem;"><?= $this->escapeHtml($entry['_action_label']) ?></span>
                <span class="text-muted"><?= $this->escapeHtml($entry['user_name'] ?: '') ?></span>
            </div>
            <!-- Line 2: Message -->
            <div style="font-size: 0.85rem; margin-top: 0.2rem;">
                <?= $this->escapeHtml($msg) ?>
            </div>
            <!-- Line 3: Chips -->
            <?php
            $chips = [];
            if (isset($d['changes_readable']) && is_array($d['changes_readable'])) {
                foreach ($d['changes_readable'] as $cr) { $chips[] = ['text' => $cr, 'class' => 'audit-chip-change']; }
            } elseif (isset($d['changes']) && is_array($d['changes'])) {
                foreach ($d['changes'] as $ck => $cv) {
                    if (is_array($cv) && isset($cv['old']) && isset($cv['new'])) {
                        $chips[] = ['text' => $ck . ': ' . $cv['old'] . ' → ' . $cv['new'], 'class' => 'audit-chip-change'];
                    }
                }
            }
            if (isset($d['paymentMethod']) && $d['paymentMethod']) {
                $pmLabel = $pmLabels[$d['paymentMethod']] ?? $d['paymentMethod'];
                $chips[] = ['text' => $pmLabel, 'class' => 'audit-chip-payment'];
            }
            if (isset($d['square_name']) && $d['square_name']) { $chips[] = ['text' => $d['square_name'], 'class' => 'audit-chip-info']; }
            if (isset($d['user_name_full']) && $d['user_name_full']) { $chips[] = ['text' => $d['user_name_full'], 'class' => 'audit-chip-info']; }
            if (isset($d['player_names']) && is_array($d['player_names'])) {
                foreach ($d['player_names'] as $pn) { $chips[] = ['text' => $pn, 'class' => 'audit-chip-info']; }
            }
            if (isset($d['budget']) && $d['budget']) { $chips[] = ['text' => 'Budget: ' . $d['budget'] . '→' . ($d['newbudget'] ?? '0'), 'class' => 'audit-chip-budget']; }
            if (isset($d['budget_old']) && isset($d['budget_new']) && $d['budget_old'] != $d['budget_new']) { $chips[] = ['text' => 'Budget: ' . ($d['budget_old'] ?: '0') . '→' . $d['budget_new'], 'class' => 'audit-chip-budget']; }
            if ($entry['ip'] && ($entry['action'] == 'login' || $entry['action'] == 'login_failed')) {
                $ipText = $entry['ip'];
                if (isset($d['countryCode']) && $d['countryCode']) { $ipText .= ' (' . $d['countryCode'] . ')'; }
                $chips[] = ['text' => $ipText, 'class' => 'audit-chip-info'];
            }
            ?>
            <?php if ($chips): ?>
            <div style="margin-top: 0.25rem;">
                <?php foreach ($chips as $chip): ?>
                    <span class="audit-chip <?= $chip['class'] ?>"><?= $this->escapeHtml($chip['text']) ?></span>
                <?php endforeach; ?>
            </div>
            <?php endif; ?>
            <!-- Detail JSON -->
            <?php if ($entry['detail']): ?>
            <div id="detail-<?= $i ?>" style="display:none; margin-top: 0.4rem;">
                <pre class="mb-0 p-2 bg-light rounded" style="font-size: 0.72rem; white-space: pre-wrap; max-height: 250px; overflow-y: auto;"><?= $this->escapeHtml(json_encode(json_decode($entry['detail']), JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE)) ?></pre>
            </div>
            <?php endif; ?>
        </div>
        <?php endforeach; ?>
    </div>

    <!-- Mobile: Card Layout -->
    <div class="d-lg-none">
        <?php foreach ($processedEntries as $entry): $i = $entry['_index']; ?>
        <div class="card mb-2">
            <div class="card-body p-2">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div>
                        <span class="badge bg-<?= $entry['_badge'][1] ?>"><?= $entry['_badge'][0] ?></span>
                        <span class="badge bg-light text-dark"><?= $this->escapeHtml($entry['action']) ?></span>
                    </div>
                    <small class="text-muted text-nowrap"><?= date('d.m. H:i', strtotime($entry['created'])) ?></small>
                </div>
                <div class="mb-1" style="font-size: 0.9rem;">
                    <?= $this->escapeHtml($entry['message']) ?>
                </div>
                <?php if ($entry['_info']): ?>
                <div class="mb-1" style="font-size: 0.8rem;">
                    <?= $entry['_info'] ?>
                </div>
                <?php endif; ?>
                <?php if ($entry['user_name']): ?>
                <div style="font-size: 0.8rem;">
                    <span class="text-muted">von</span> <?= $this->escapeHtml($entry['user_name']) ?>
                </div>
                <?php endif; ?>
                <?php if ($entry['detail']): ?>
                <div class="mt-1">
                    <a href="#" class="btn btn-sm btn-outline-secondary py-0 px-1" style="font-size: 0.75rem;" onclick="var d=document.getElementById('detail-m-<?= $i ?>');d.style.display=d.style.display=='none'?'block':'none';return false;">
                        <span class="fa fa-info-circle"></span> JSON
                    </a>
                    <div id="detail-m-<?= $i ?>" style="display: none;" class="mt-1">
                        <pre class="mb-0 p-2 bg-light" style="font-size: 0.7rem; white-space: pre-wrap; max-height: 200px; overflow-y: auto;"><?= $this->escapeHtml(json_encode(json_decode($entry['detail']), JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE)) ?></pre>
                    </div>
                </div>
                <?php endif; ?>
            </div>
        </div>
        <?php endforeach; ?>
    </div>

    <?php endif; ?>
</div>
