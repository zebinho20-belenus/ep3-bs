# Copy this file to .env and adjust values
# cp .env.example .env

# App Hostname (used by Traefik routing)
# court.localhost resolves to 127.0.0.1 in most browsers
APP_HOSTNAME=court.localhost

# Traefik
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8080

# MariaDB
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=mycourt
MYSQL_USER=mycourt
MYSQL_PASSWORD=mycourt
MYSQL_PORT=3306

# MailHog
MAILHOG_UI_PORT=8025

# Xdebug: true = DEV (with debug), false = PROD (without debug)
INSTALL_XDEBUG=true

# Docker Socket
# Linux / macOS Colima: /var/run/docker.sock (default)
# macOS Docker Desktop: ~/.docker/run/docker.sock
DOCKER_SOCKET=/var/run/docker.sock
